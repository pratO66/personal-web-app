# Copy this file to .env and fill in values before running docker compose.
# Never commit .env — it is gitignored.

# ── Database ───────────────────────────────────────────────────────────────────
# For Docker Compose local dev (supabase-db container):
SUPABASE_DB_PASSWORD=your-supabase-db-password

# For Spring Boot docker profile:
SPRING_DATASOURCE_URL=jdbc:postgresql://supabase-db:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-supabase-db-password

# Connection pool size (default: 10 for docker, 5 for dev)
DB_POOL_SIZE=10

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-here-make-it-long-and-secure
JWT_EXPIRY_MS=86400000

# ── Admin ──────────────────────────────────────────────────────────────────────
# Generate hash: htpasswd -bnBC 12 "" "yourpassword" | tr -d ':\n'
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$12$LQv3c1yqBWVHxkd0LHAkCOYz6TtxMQJqhN8/LewdBPj8lLxKQZK.

# ── Email (optional — leave blank to disable; messages still saved to DB) ──────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
CONTACT_NOTIFY_TO=your-email@gmail.com

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8080
CORS_ORIGIN=http://localhost:3000

# ── Frontend ───────────────────────────────────────────────────────────────────
# BACKEND_URL: server-only runtime var used by RSC fetches — never baked into bundle.
# Set this in Vercel env vars (not build env) to your deployed backend URL.
BACKEND_URL=https://your-backend.railway.app

# NEXT_PUBLIC_API_URL: baked into the JS bundle at build time (for ContactForm client fetch).
# Must match BACKEND_URL. Set in Vercel build env vars.
NEXT_PUBLIC_API_URL=https://your-backend.railway.app
NEXT_PUBLIC_SITE_NAME=V // Night City Dev
NEXT_PUBLIC_SITE_URL=https://your-vercel-app.vercel.app
